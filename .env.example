# Mizan GRC — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.

# ── Required ─────────────────────────────────────────────────────────────────
# Flask session secret — use a long random string in production
SECRET_KEY=change-me-to-a-long-random-string

# Admin account password (set before first deploy)
ADMIN_PASSWORD=change-me

# ── AI Providers (at least one required) ─────────────────────────────────────
# Claude (primary / recommended)
ANTHROPIC_API_KEY=

# OpenAI GPT-4 (optional fallback)
OPENAI_API_KEY=

# Google Gemini (optional fallback)
GOOGLE_API_KEY=

# Groq / Llama (optional fallback)
GROQ_API_KEY=

# DeepSeek (optional fallback)
DEEPSEEK_API_KEY=

# Force a specific provider: anthropic | openai | google | groq | deepseek | auto
AI_PROVIDER=auto

# Override the model name (leave empty for provider default)
AI_MODEL=

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (default: ./mizan.db)
DATABASE_PATH=./mizan.db

# ── Email / OTP ───────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mizan.app
SMTP_USE_TLS=true

# ── Deployment ────────────────────────────────────────────────────────────────
FLASK_ENV=development
# Absolute URL used for share links in emails
PRODUCTION_DOMAIN=https://mizan.app
# Password-reset token expiry in minutes
PASSWORD_RESET_EXPIRY=30
